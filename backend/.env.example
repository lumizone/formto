# FormTo Backend — Local Development Environment
# Copy: cp .env.example .env
# Then fill in your values.

# PostgreSQL connection string
DATABASE_URL=postgresql://formto:localdev@localhost:5432/formto

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-at-least-32-chars-long

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# SMTP (optional — can also be configured per-account in the UI)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=FormTo <noreply@localhost>

# File upload size limit in MB
MAX_FILE_SIZE_MB=10

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
